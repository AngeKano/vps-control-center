# ============================================
# VPS CONTROL CENTER - Configuration
# ============================================

# Base de données PostgreSQL
DATABASE_URL="postgresql://vps_admin:VpsControl2025!@localhost:5432/vps_control?schema=public"

# NextAuth - GÉNÉRER UN SECRET UNIQUE
# Commande: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGEZ_MOI_EN_PRODUCTION"

# URL du dashboard
# Local: http://localhost:3000
# Distant: http://VOTRE_IP:3000
NEXTAUTH_URL="http://localhost:3000"

# Clé API pour communiquer avec les agents VPS
# DOIT ÊTRE IDENTIQUE sur tous les agents
# Commande: openssl rand -hex 32
VPS_API_KEY="CHANGEZ_MOI_DOIT_CORRESPONDRE_AUX_AGENTS"

# Environment
NODE_ENV="development"
